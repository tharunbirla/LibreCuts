<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Home Page Content -->
    <LinearLayout
        android:id="@+id/layoutHomeContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="80dp"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/btnImport"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/bg_import_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:elevation="8dp">

            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circle_primary_container" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="-60dp"
                android:src="@drawable/ic_add_24"
                app:tint="@color/onPrimaryContainer" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:letterSpacing="0.2"
                android:text="@string/str_new_project"
                android:textColor="@color/textColor"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_tap_to_select_media"
                android:textColor="@color/iconSecondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:lineSpacingMultiplier="1.4"
            android:text="@string/str_free_open_source_nlimitless_cr"
            android:textColor="@color/colorOnSurface"
            android:alpha="0.5"
            android:textSize="18sp"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>

    <!-- Settings Page Content -->
    <ScrollView
        android:id="@+id/layoutSettingsContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:padding="24dp"
        android:paddingBottom="120dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_settings"
                android:textColor="@color/textColor"
                android:textSize="28sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_import_card"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/str_general"
                    android:textColor="@color/textColor"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp" />

                <!-- Video Export Folder Setting -->
                <LinearLayout
                    android:id="@+id/btnChangeExportFolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="12dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str_video_export_folder"
                        android:textColor="@color/textColor"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    
                    <TextView
                        android:id="@+id/tvCurrentExportFolder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_default_movies_librecuts"
                        android:textColor="@color/iconSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline"
                    android:layout_marginVertical="4dp" />

                <!-- Audio Export Folder Setting -->
                <LinearLayout
                    android:id="@+id/btnChangeAudioExportFolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="12dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str_audio_export_folder"
                        android:textColor="@color/textColor"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    
                    <TextView
                        android:id="@+id/tvCurrentAudioExportFolder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_default_music_librecuts"
                        android:textColor="@color/iconSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline"
                    android:layout_marginVertical="4dp" />

                <!-- Snapshot Export Folder Setting -->
                <LinearLayout
                    android:id="@+id/btnChangeSnapshotExportFolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="12dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str_snapshot_export_folder"
                        android:textColor="@color/textColor"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    
                    <TextView
                        android:id="@+id/tvCurrentSnapshotExportFolder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_default_pictures_librecuts"
                        android:textColor="@color/iconSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline"
                    android:layout_marginVertical="8dp" />

                <!-- Check for Updates Setting -->
                <LinearLayout
                    android:id="@+id/btnCheckForUpdates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="12dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str_check_for_updates"
                        android:textColor="@color/textColor"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_manually_check_for_the_latest"
                        android:textColor="@color/iconSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline"
                    android:layout_marginVertical="8dp" />

                <!-- Open Source Licenses Setting -->
                <LinearLayout
                    android:id="@+id/btnOpenSourceLicenses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="12dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str_open_source_licenses"
                        android:textColor="@color/textColor"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_view_third_party_software_licenses"
                        android:textColor="@color/iconSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- About Page Content -->
    <ScrollView
        android:id="@+id/layoutAboutContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:padding="24dp"
        android:paddingBottom="120dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="32dp"
                android:src="@mipmap/ic_launcher_round" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/app_name"
                android:textColor="@color/textColor"
                android:textSize="28sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.6"
                android:text="@string/str_v1_0_beta4"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"
                android:text="@string/str_a_privacy_friendly_open_source"
                android:textColor="@color/iconSecondary"
                android:textSize="15sp" />

            <!-- Support & Feedback Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_import_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/str_support_amp_feedback"
                    android:textColor="@color/textColor"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/str_librecuts_is_open_source_help"
                    android:textColor="@color/iconSecondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStarGithub"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="@string/str_star_on_github"
                    android:textColor="@color/onPrimaryContainer"
                    android:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="16dp"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_star_24"
                    app:iconTint="@color/onPrimaryContainer"
                    app:iconGravity="textStart"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReportBug"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/str_report_a_bug"
                    android:textColor="@color/textColor"
                    android:backgroundTint="@color/surfaceContainerHigh"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="1dp"
                    app:cornerRadius="16dp"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_bug_24"
                    app:iconTint="@color/textColor"
                    app:iconGravity="textStart"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSponsor"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/str_sponsor_project"
                    android:textColor="#ff69b4"
                    android:backgroundTint="@color/surfaceContainerHigh"
                    app:strokeColor="#ff69b4"
                    app:strokeWidth="1dp"
                    app:cornerRadius="16dp"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_heart_24"
                    app:iconTint="#ff69b4"
                    app:iconGravity="textStart"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:alpha="0.4"
                android:text="@string/str_made_by_tharun_birla"
                android:textColor="@color/textColor"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar (Floating Pill) -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="260dp"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_bottom_nav_floating"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:elevation="24dp">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <FrameLayout
                android:id="@+id/tabHome"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_nav_active_pill"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_home_24"
                    app:tint="@color/colorPrimary" />
            </FrameLayout>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <FrameLayout
                android:id="@+id/tabSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivSettings"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_settings_24"
                    app:tint="@color/inactiveTool" />
            </FrameLayout>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <FrameLayout
                android:id="@+id/tabAbout"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivAbout"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_info_24"
                    app:tint="@color/inactiveTool" />
            </FrameLayout>
        </FrameLayout>

    </LinearLayout>

</RelativeLayout>
