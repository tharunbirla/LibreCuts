<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".VideoEditingActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnHome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_back_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Back"
                app:tint="@color/colorOnPrimary" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnUndo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_undo_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:contentDescription="Undo"
                android:layout_marginEnd="8dp"
                android:alpha="0.5"
                android:enabled="false"/>

            <ImageButton
                android:id="@+id/btnRedo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_redo_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:contentDescription="Redo"
                android:layout_marginEnd="16dp"
                android:alpha="0.5"
                android:enabled="false"/>

            <ImageButton
                android:id="@+id/btnPreview"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_preview_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:contentDescription="Preview Render"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                app:tint="@color/colorOnPrimary" />

            <LinearLayout
                android:id="@+id/layoutSaveSplit"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_split_save_button"
                android:clipToOutline="true"
                android:elevation="0dp">

                <TextView
                    android:id="@+id/btnSaveText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.75"
                    android:gravity="center"
                    android:text="@string/export"
                    android:textColor="@color/onPrimaryContainer"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#33FFFFFF" />

                <ImageView
                    android:id="@+id/btnSaveDropdown"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.25"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_arrow_drop_down_24"
                    android:padding="8dp"
                    app:tint="@color/onPrimaryContainer"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/playerContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/surfaceContainer"
            android:elevation="8dp"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <com.google.android.exoplayer2.ui.StyledPlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false"
                app:surface_type="texture_view"
                android:background="@color/cinemaBlack" />


            <com.tharunbirla.librecuts.customviews.TextOverlayView
                android:id="@+id/textOverlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <com.tharunbirla.librecuts.customviews.DraggableTextOverlayView
                android:id="@+id/draggableTextOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <com.tharunbirla.librecuts.customviews.ImageOverlayView
                android:id="@+id/imageOverlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <com.tharunbirla.librecuts.customviews.DraggableImageOverlayView
                android:id="@+id/draggableImageOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <com.tharunbirla.librecuts.customviews.CropOverlayView
                android:id="@+id/cropOverlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvPreviewBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:text="@string/str_preview"
                android:textColor="@color/textColor"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/rounded_time_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="16dp"
                android:background="@drawable/rounded_time_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/str_0_00_0_00"
                android:textColor="@color/textColor"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/seekerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surfaceContainerHigh"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="start|center_vertical">

                    <ImageButton
                        android:id="@+id/btnMoveLayerUp"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_arrow_up_24"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:visibility="gone"
                        app:tint="@color/colorOnSecondary" />

                    <ImageButton
                        android:id="@+id/btnMoveLayerDown"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_arrow_down_24"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:visibility="gone"
                        app:tint="@color/colorOnSecondary" />
                </LinearLayout>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btnPlayPause"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_play_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/colorOnSecondary" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="end|center_vertical">

                    <ImageButton
                        android:id="@+id/btnCaptureFrame"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_camera_capture"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:tint="@color/colorOnSecondary" />

                    <ImageButton
                        android:id="@+id/btnMagnet"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_magnet_24"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:tint="@color/colorOnSecondary" />

                    <ImageButton
                        android:id="@+id/btnMute"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_volume_up_24"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        app:tint="@color/colorOnSecondary" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/timelineContainer"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="16dp">

                <HorizontalScrollView
                    android:id="@+id/timelineHorizontalScroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/scrollableTimelineContent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:clipChildren="false">

                        <com.tharunbirla.librecuts.customviews.TimeRulerView
                            android:id="@+id/timeRulerView"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@color/colorSurface" />

                        <ScrollView
                            android:id="@+id/timelineVerticalScroll"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:clipToPadding="false"
                            android:clipChildren="false"
                            android:scrollbars="none">
                            
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:clipChildren="false"
                                android:paddingBottom="16dp">
                                
                                <!-- Video Track Sequence Container -->
                                <FrameLayout
                                    android:id="@+id/sequenceTrackContainer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="64dp"
                                    android:layout_marginBottom="4dp"
                                    android:clipChildren="false">
                                </FrameLayout>

                                <!-- Text Track Container -->
                                <LinearLayout
                                    android:id="@+id/textTrackContainer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:clipChildren="false"
                                    android:visibility="gone"/>

                                <!-- Image Track Container -->
                                <LinearLayout
                                    android:id="@+id/imageTrackContainer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:clipChildren="false"
                                    android:visibility="gone"/>

                                <!-- Audio Track Container -->
                                <LinearLayout
                                    android:id="@+id/audioTrackContainer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:clipChildren="false"
                                    android:visibility="gone"/>

                            </LinearLayout>
                        </ScrollView>
                    </LinearLayout>
                </HorizontalScrollView>

                <ImageButton
                    android:id="@+id/btnTimelineAdd"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_primary_container"
                    android:src="@drawable/ic_add_24"
                    android:contentDescription="Add Media"
                    android:elevation="8dp"
                    android:padding="8dp"
                    app:tint="@color/colorOnPrimary" />

                <com.tharunbirla.librecuts.customviews.CustomVideoSeeker
                    android:id="@+id/customVideoSeeker"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="10dp"
                    android:clickable="false"
                    android:focusable="false" />

                <LinearLayout
                    android:id="@+id/emptyProjectState"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone"
                    android:background="@drawable/bg_bottom_nav_floating"
                    android:elevation="2dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_add_24"
                        android:background="@drawable/circle_primary_container"
                        android:padding="12dp"
                        app:tint="@color/colorOnPrimary" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/str_timeline_empty"
                        android:textSize="16sp"
                        android:textColor="@color/textColor"
                        android:fontFamily="sans-serif-medium" />
                        
                    <Button
                        android:id="@+id/btnEmptyImportVideo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/str_import_video"
                        app:cornerRadius="8dp"
                        android:textColor="@color/onPrimaryContainer"
                        android:backgroundTint="@color/colorPrimary" />
                </LinearLayout>
            </FrameLayout>

            <View
                android:id="@+id/timelineDivider"
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:background="@color/outlineVariant"
                android:alpha="0.4"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />
        </LinearLayout>

        <!-- Text Editing Toolbar (inline mode, hidden by default) -->
        <include
            android:id="@+id/textEditingToolbar"
            layout="@layout/text_editing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- Image Editing Toolbar (inline mode, hidden by default) -->
        <include
            android:id="@+id/imageEditingToolbar"
            layout="@layout/image_editing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- Video Editing Toolbar (inline mode, hidden by default) -->
        <include
            android:id="@+id/videoEditingToolbar"
            layout="@layout/video_editing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- Audio Editing Toolbar (inline mode, hidden by default) -->
        <include
            android:id="@+id/audioEditingToolbar"
            layout="@layout/audio_editing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- Crop Editing Toolbar (inline mode, hidden by default) -->
        <include
            android:id="@+id/cropEditingToolbar"
            layout="@layout/crop_editing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- Speed Editing Toolbar (inline mode, hidden by default) -->
        <include
            android:id="@+id/speedEditingToolbar"
            layout="@layout/speed_editing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- Subtitles Editing Toolbar (inline mode, hidden by default) -->
        <include
            android:id="@+id/subtitlesEditingToolbar"
            layout="@layout/subtitles_editing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <HorizontalScrollView
            android:id="@+id/editingControlsScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="16dp"
            android:scrollbars="none"
            android:background="@drawable/bg_bottom_nav_floating"
            android:elevation="12dp"
            android:clipToOutline="true"
            android:requiresFadingEdge="horizontal"
            android:fadingEdgeLength="32dp"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/editingControlsWrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:paddingHorizontal="8dp">

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/btnText"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/tool_button_inactive"
                        android:src="@drawable/ic_text_24"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        app:tint="@color/toolTextInactive" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_text"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/toolTextInactive"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/btnMediaOverlay"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/tool_button_inactive"
                        android:src="@drawable/ic_layers_24"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        app:tint="@color/toolTextInactive" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_overlay"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/toolTextInactive"/>
                </LinearLayout>



                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/btnAudio"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/tool_button_inactive"
                        android:src="@drawable/ic_audio_24"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        app:tint="@color/toolTextInactive" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_audio"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/toolTextInactive"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/btnVoiceOver"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/tool_button_inactive"
                        android:src="@drawable/ic_mic_24"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        app:tint="@color/toolTextInactive" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_voice"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/toolTextInactive"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/btnSubtitles"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/tool_button_inactive"
                        android:src="@drawable/ic_closed_caption_24"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        app:tint="@color/toolTextInactive" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_subtitles"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/toolTextInactive"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/btnCrop"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/tool_button_inactive"
                        android:src="@drawable/ic_crop_24"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        app:tint="@color/toolTextInactive" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/str_crop"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/toolTextInactive"/>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <include
        android:id="@+id/loadingScreen"
        layout="@layout/loading_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <include
        android:id="@+id/exportScreen"
        layout="@layout/export_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/previewLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="#FF4081" />
    </FrameLayout>



</RelativeLayout>