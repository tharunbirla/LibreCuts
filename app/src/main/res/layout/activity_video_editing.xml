<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/cinemaBlack"
    tools:context=".VideoEditingActivity"
    android:orientation="vertical">

    <!-- Top toolbar with home, undo, redo, save buttons -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#99000000"
        android:padding="8dp"
        android:layout_alignParentTop="true">

        <ImageButton
            android:id="@+id/btnHome"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_home_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/home"
            android:layout_marginEnd="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:gravity="end">

            <ImageButton
                android:id="@+id/btnUndo"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_undo_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Undo"
                android:layout_marginEnd="8dp"
                android:alpha="0.5"
                android:enabled="false"/>

            <ImageButton
                android:id="@+id/btnRedo"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_redo_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Redo"
                android:layout_marginEnd="16dp"
                android:alpha="0.5"
                android:enabled="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save"
                android:textSize="12sp"
                android:textColor="@color/colorOnPrimary"
                android:contentDescription="@string/save_video"
                android:layout_marginEnd="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="24dp"
                app:strokeColor="@color/colorOnPrimary"
                app:strokeWidth="1dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>
        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <!-- Cinematic video player container -->
    <FrameLayout
        android:id="@+id/playerContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_above="@+id/textConfigs"
        android:layout_below="@+id/toolbar"
        android:background="@color/cinemaBlack">

        <com.google.android.exoplayer2.ui.StyledPlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false" />

        <com.tharunbirla.librecuts.customviews.TextOverlayView
            android:id="@+id/textOverlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>

    <!-- Text configurations panel -->
    <LinearLayout
        android:id="@+id/textConfigs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_above="@+id/seekerContainer"/>

    <!-- Timeline/Seeker container -->
    <LinearLayout
        android:id="@+id/seekerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_above="@+id/editingControlsWrapper">

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_time_stamp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_gravity="center_horizontal"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/frameRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <com.tharunbirla.librecuts.customviews.CustomVideoSeeker
                android:id="@+id/customVideoSeeker"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Floating control panel wrapper with individual floating buttons -->
    <LinearLayout
        android:id="@+id/editingControlsWrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="20dp"
        android:paddingTop="12dp"
        android:spacing="12dp">

        <!-- Individual floating button: Trim -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/floating_panel_background"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="6dp">

            <ImageButton
                android:id="@+id/btnTrim"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:src="@drawable/ic_split_24"
                android:background="@drawable/button_ripple_effect"
                android:contentDescription="Trim"
                app:tint="@color/colorOnSecondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trim"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Individual floating button: Text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/floating_panel_background"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="6dp">

            <ImageButton
                android:id="@+id/btnText"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:src="@drawable/ic_text_24"
                android:background="@drawable/button_ripple_effect"
                android:contentDescription="Text"
                app:tint="@color/colorOnSecondary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Individual floating button: Audio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/floating_panel_background"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="6dp">

            <ImageButton
                android:id="@+id/btnAudio"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:src="@drawable/ic_audio_24"
                android:background="@drawable/button_ripple_effect"
                android:contentDescription="Audio"
                app:tint="@color/colorOnSecondary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Individual floating button: Crop -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/floating_panel_background"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="6dp">

            <ImageButton
                android:id="@+id/btnCrop"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:src="@drawable/ic_crop_24"
                android:background="@drawable/button_ripple_effect"
                android:contentDescription="Crop"
                app:tint="@color/colorOnSecondary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crop"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Individual floating button: Merge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/floating_panel_background"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/btnMerge"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:src="@drawable/ic_add_photos_24"
                android:background="@drawable/button_ripple_effect"
                android:contentDescription="Merge"
                app:tint="@color/colorOnSecondary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Merge"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Loading and Export overlays -->
    <include
        layout="@layout/loading_screen"
        android:id="@+id/loadingScreen"
        android:visibility="gone"/>

    <include
        layout="@layout/export_screen"
        android:id="@+id/exportScreen"
        android:visibility="gone"/>

</RelativeLayout>
