<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".VideoEditingActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnHome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_back_24"
                android:contentDescription="Back"
                app:tint="@color/colorOnPrimary" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnUndo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_undo_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Undo"
                android:layout_marginEnd="8dp"
                android:alpha="0.5"
                android:enabled="false"/>

            <ImageButton
                android:id="@+id/btnRedo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_redo_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Redo"
                android:layout_marginEnd="16dp"
                android:alpha="0.5"
                android:enabled="false"/>

            <ImageButton
                android:id="@+id/btnPreview"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_preview_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Preview Render"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                app:tint="@color/colorOnPrimary" />

            <LinearLayout
                android:id="@+id/layoutSaveSplit"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_split_save_button"
                android:clipToOutline="true"
                android:elevation="0dp">

                <TextView
                    android:id="@+id/btnSaveText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.75"
                    android:gravity="center"
                    android:text="Export"
                    android:textColor="@color/onPrimaryContainer"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#33FFFFFF" />

                <ImageView
                    android:id="@+id/btnSaveDropdown"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.25"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_arrow_drop_down_24"
                    android:padding="8dp"
                    app:tint="@color/onPrimaryContainer"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/playerContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/surfaceContainer"
            android:elevation="8dp"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <com.google.android.exoplayer2.ui.StyledPlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false"
                android:background="@color/cinemaBlack" />

            <com.tharunbirla.librecuts.customviews.TextOverlayView
                android:id="@+id/textOverlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <com.tharunbirla.librecuts.customviews.DraggableTextOverlayView
                android:id="@+id/draggableTextOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <com.tharunbirla.librecuts.customviews.ImageOverlayView
                android:id="@+id/imageOverlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <com.tharunbirla.librecuts.customviews.DraggableImageOverlayView
                android:id="@+id/draggableImageOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvPreviewBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:text="PREVIEW"
                android:textColor="@color/textColor"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/rounded_time_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="16dp"
                android:background="@drawable/rounded_time_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="0:00 / 0:00"
                android:textColor="@color/textColor"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/seekerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surfaceContainerHigh"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="4dp">

                <ImageButton
                    android:id="@+id/btnDeleteLayer"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_delete_24"
                    app:tint="@color/colorOnSecondary"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btnPlayPause"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_play_24"
                    app:tint="@color/colorOnSecondary" />


                <ImageButton
                    android:id="@+id/btnMute"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_volume_up_24"
                    app:tint="@color/colorOnSecondary" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/timelineContainer"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="16dp">

                <HorizontalScrollView
                    android:id="@+id/timelineHorizontalScroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/scrollableTimelineContent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <com.tharunbirla.librecuts.customviews.TimeRulerView
                            android:id="@+id/timeRulerView"
                            android:layout_width="wrap_content"
                            android:layout_height="24dp"
                            android:background="@color/background" />

                        <ScrollView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:clipToPadding="false"
                            android:scrollbars="none">
                            
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingBottom="16dp">
                                
                                <!-- Video Track Sequence Container -->
                                <LinearLayout
                                    android:id="@+id/sequenceTrackContainer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="64dp"
                                    android:layout_marginBottom="4dp"
                                    android:orientation="horizontal">
                                </LinearLayout>

                                <!-- Text Track Container -->
                                <LinearLayout
                                    android:id="@+id/textTrackContainer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:visibility="gone"/>

                                <!-- Image Track Container -->
                                <LinearLayout
                                    android:id="@+id/imageTrackContainer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:visibility="gone"/>

                                <!-- Audio Track Container -->
                                <LinearLayout
                                    android:id="@+id/audioTrackContainer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:visibility="gone"/>

                            </LinearLayout>
                        </ScrollView>
                    </LinearLayout>
                </HorizontalScrollView>

                <com.tharunbirla.librecuts.customviews.CustomVideoSeeker
                    android:id="@+id/customVideoSeeker"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="10dp"
                    android:clickable="false"
                    android:focusable="false" />
            </FrameLayout>

            <View
                android:id="@+id/timelineDivider"
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:background="@color/outlineVariant"
                android:alpha="0.4"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />
        </LinearLayout>

        <!-- Text Editing Toolbar (inline mode, hidden by default) -->
        <include
            android:id="@+id/textEditingToolbar"
            layout="@layout/text_editing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <!-- Image Editing Toolbar (inline mode, hidden by default) -->
        <include
            android:id="@+id/imageEditingToolbar"
            layout="@layout/image_editing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/editingControlsWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@color/navigationBarColor"
            android:paddingTop="8dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnText"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_text_24"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Text"
                    android:textSize="11sp"
                    android:textColor="@color/toolTextInactive"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnImageOverlay"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_sticker_24"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stickers"
                    android:textSize="11sp"
                    android:textColor="@color/toolTextInactive"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnAudio"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_audio_24"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audio"
                    android:textSize="11sp"
                    android:textColor="@color/toolTextInactive"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnCrop"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_crop_24"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crop"
                    android:textSize="11sp"
                    android:textColor="@color/toolTextInactive"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnMerge"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_add_24"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add"
                    android:textSize="11sp"
                    android:textColor="@color/toolTextInactive"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <include
        android:id="@+id/loadingScreen"
        layout="@layout/loading_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <include
        android:id="@+id/exportScreen"
        layout="@layout/export_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/previewLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="#FF4081" />
    </FrameLayout>

</RelativeLayout>