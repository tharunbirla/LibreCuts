<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Rotation Slider Row -->
    <LinearLayout
        android:id="@+id/imageRotationSliderRow"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bottom_nav_floating"
        android:paddingHorizontal="16dp"
        android:elevation="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_rotate_right_24"
            app:tint="@color/iconSecondary" />

        <com.google.android.material.slider.Slider
            android:id="@+id/imageRotationSlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="0.0"
            android:valueTo="360.0"
            android:value="0.0"
            android:stepSize="1.0"
            app:thumbColor="@color/colorPrimary"
            app:trackColorActive="@color/colorPrimary" />

        <TextView
            android:id="@+id/tvImageRotationValue"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="@string/str_0_1"
            android:textColor="@color/textColor"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Opacity Slider Row -->
    <LinearLayout
        android:id="@+id/imageOpacitySliderRow"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bottom_nav_floating"
        android:paddingHorizontal="16dp"
        android:elevation="12dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_opacity_24"
            app:tint="@color/iconSecondary" />

        <com.google.android.material.slider.Slider
            android:id="@+id/imageOpacitySlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="0.0"
            android:valueTo="100.0"
            android:value="100.0"
            android:stepSize="1.0"
            app:thumbColor="@color/colorPrimary"
            app:trackColorActive="@color/colorPrimary" />

        <TextView
            android:id="@+id/tvImageOpacityValue"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="@string/str_100"
            android:textColor="@color/textColor"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Toolbar Row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:scrollbars="none"
        android:background="@drawable/bg_bottom_nav_floating"
        android:elevation="12dp"
        android:clipToOutline="true"
        android:requiresFadingEdge="horizontal"
        android:fadingEdgeLength="32dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:paddingHorizontal="8dp">

        <!-- Cancel -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnImageCancel"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_close_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/cancel"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Duplicate -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnImageDuplicate"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_copy_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_duplicate"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Mirror -->
        <LinearLayout
            android:id="@+id/btnImageMirrorContainer"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnImageMirror"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_mirror"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:id="@+id/tvImageMirror"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Mirror"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Chroma Key -->
        <LinearLayout
            android:id="@+id/btnImageChromaKeyContainer"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnImageChromaKey"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_color_lens_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:id="@+id/tvImageChromaKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chroma Key"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Opacity -->
        <LinearLayout
            android:id="@+id/btnImageOpacityContainer"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnImageOpacity"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_opacity_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:id="@+id/tvImageOpacity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_opacity"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>


        <!-- Loop -->
        <LinearLayout
            android:id="@+id/btnImageLoopContainer"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <ImageButton
                android:id="@+id/btnImageLoop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_loop_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:id="@+id/tvImageLoop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_loop"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Keyframe -->
        <LinearLayout
            android:id="@+id/btnImageKeyframeContainer"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnImageKeyframe"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_keyframe_main"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Keyframes"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Delete -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnImageDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_delete_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="#F44336" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/delete"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#F44336"/>
        </LinearLayout>
        <!-- Done -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnImageDone"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_check_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/colorPrimary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/done"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/colorPrimary"/>
        </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
