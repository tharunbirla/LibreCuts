<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Volume Slider Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bottom_nav_floating"
        android:paddingHorizontal="16dp"
        android:elevation="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_volume_up_24"
            app:tint="@color/iconSecondary" />

        <com.google.android.material.slider.Slider
            android:id="@+id/audioVolumeSlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="0.0"
            android:valueTo="2.0"
            android:value="1.0"
            app:thumbColor="@color/colorPrimary"
            app:trackColorActive="@color/colorPrimary" />

        <TextView
            android:id="@+id/tvAudioVolumeValue"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="@string/str_100"
            android:textColor="@color/textColor"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Audio Trim Row -->
    <LinearLayout
        android:id="@+id/audioTrimRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_nav_floating"
        android:padding="16dp"
        android:elevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_audio_segment"
                android:textColor="@color/textColor"
                android:fontFamily="sans-serif-medium"/>
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
            <TextView
                android:id="@+id/tvAudioTrimValues"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_0_0s_0_0s"
                android:textColor="@color/outline"
                android:textSize="12sp"/>
        </LinearLayout>

        <com.tharunbirla.librecuts.customviews.TrackTrimView
            android:id="@+id/audioTrimTrack"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp" />
        
        <ImageButton
            android:id="@+id/btnAudioPreviewPlay"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_play_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:scaleType="fitCenter"
            app:tint="@color/colorPrimary" />
    </LinearLayout>

    <!-- Toolbar Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_bottom_nav_docked"
        android:paddingVertical="8dp"
        android:paddingHorizontal="8dp"
        android:elevation="12dp">

        <!-- Cancel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnAudioCancel"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_close_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/cancel"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Beats -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnAudioBeats"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_bolt_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_beats"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Ducking -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnAudioDucking"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_ducking"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_ducking"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Fade -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnAudioFade"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_fade"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/str_fade"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Delete -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnAudioDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_delete_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="#F44336" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/delete"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#F44336"/>
        </LinearLayout>

        <!-- Done -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnAudioDone"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_check_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/colorPrimary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/done"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/colorPrimary"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
