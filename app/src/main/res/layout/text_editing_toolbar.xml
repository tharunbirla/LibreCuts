<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Color Picker Container (Visible in Palette Mode) -->
    <HorizontalScrollView
        android:id="@+id/colorPickerContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:scrollbars="none"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_bottom_nav_floating"
        android:elevation="12dp"
        android:visibility="gone">
        <LinearLayout
            android:id="@+id/colorPickerList"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp" />
    </HorizontalScrollView>

    <!-- Format Settings Container -->
    <include layout="@layout/text_format_settings"
        android:id="@+id/formatSettingsContainer"
        android:visibility="gone" />

    <!-- Toolbar Row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:scrollbars="none"
        android:background="@drawable/bg_bottom_nav_floating"
        android:elevation="12dp"
        android:clipToOutline="true"
        android:requiresFadingEdge="horizontal"
        android:fadingEdgeLength="32dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:paddingHorizontal="8dp">

            <!-- Cancel -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnTextCancel"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_close_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/cancel"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/toolTextInactive" />
            </LinearLayout>

            <!-- Keyboard -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnTextKeyboardTab"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_keyboard_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/str_keyboard"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/colorPrimary" />
            </LinearLayout>

            <!-- Color Palette -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnTextPaletteTab"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_palette_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/str_color"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/toolTextInactive" />
            </LinearLayout>

            <!-- Format Settings -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnTextFormatTab"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_format_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Format"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/toolTextInactive" />
            </LinearLayout>

            <!-- Duplicate -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnTextDuplicate"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_copy_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/str_duplicate"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/toolTextInactive" />
            </LinearLayout>

            <!-- Keyframes -->
            <LinearLayout
                android:id="@+id/btnTextKeyframeContainer"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnTextKeyframe"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_keyframe_main"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/toolTextInactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Keyframes"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/toolTextInactive" />
            </LinearLayout>

            <!-- Delete -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnTextDelete"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_delete_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="#F44336" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/delete"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#F44336" />
            </LinearLayout>

            <!-- Done -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnTextDone"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/tool_button_inactive"
                    android:src="@drawable/ic_check_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/done"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/colorPrimary" />
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
