<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#121212">

    <!-- Handle indicator on top of bottom sheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#444444"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#444444"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btnCloseTrimSheet"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@android:color/white"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

        <TextView
            android:id="@+id/tvTrimDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00 - 00:00 (00:00)"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="24dp"
        android:background="#1E1E1E">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/trimRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false" />

        <!-- Overlay our custom TrackTrimView with transparent fill but visible trim handles/border -->
        <com.tharunbirla.librecuts.customviews.TrackTrimView
            android:id="@+id/trimTrackView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <Button
        android:id="@+id/btnDoneTrim"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Done"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/colorPrimary"
        android:paddingVertical="12dp"
        app:cornerRadius="12dp" />

</LinearLayout>