<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_bottom_nav_floating"
        android:padding="24dp"
        android:elevation="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_trim_video"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/textColor"
                android:layout_centerVertical="true" />

            <ImageButton
                android:id="@+id/btnCloseTrimSheet"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/iconSecondary"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvTrimDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str_00_00_00_00_00_00"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/colorPrimary"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/rounded_time_bg"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/trimRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false" />

            <!-- Overlay our custom TrackTrimView with transparent fill but visible trim handles/border -->
            <com.tharunbirla.librecuts.customviews.TrackTrimView
                android:id="@+id/trimTrackView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDoneTrim"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/done"
            android:textColor="@color/onPrimaryContainer"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="@color/primaryContainer"
            app:cornerRadius="24dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:elevation="0dp" />

    </LinearLayout>
</LinearLayout>