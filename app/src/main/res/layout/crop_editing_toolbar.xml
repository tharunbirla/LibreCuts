<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_bottom_nav_floating"
        android:paddingVertical="16dp"
        android:elevation="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="24dp">

            <ImageButton
                android:id="@+id/btnCloseSheet"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/activeTool" />

            <TextView
                android:id="@+id/tvTitleCrop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_crop_aspect_ratio"
                android:textColor="@color/textColor"
                android:textSize="18sp" />

            <ImageButton
                android:id="@+id/btnCropDone"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_check_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/activeTool" />
        </RelativeLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layout_gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp">

                <LinearLayout
                    android:id="@+id/frameAspectRatio1"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <FrameLayout
                        android:id="@+id/bg16_9"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_aspect_ratio_item">
                        <ImageView
                            android:id="@+id/ic16_9"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_crop_16_9_24"
                            app:tint="@color/iconSecondary" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/txt16_9"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/str_16_9"
                        android:textColor="@color/toolTextInactive"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frameAspectRatio2"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <FrameLayout
                        android:id="@+id/bg9_16"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_aspect_ratio_item">
                        <ImageView
                            android:id="@+id/ic9_16"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_crop_portrait_24"
                            app:tint="@color/iconSecondary" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/txt9_16"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/str_9_16"
                        android:textColor="@color/toolTextInactive"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frameAspectRatio3"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <FrameLayout
                        android:id="@+id/bg1_1"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_aspect_ratio_item">
                        <ImageView
                            android:id="@+id/ic1_1"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_crop_square_24"
                            app:tint="@color/iconSecondary" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/txt1_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/str_1_1"
                        android:textColor="@color/toolTextInactive"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frameAspectRatioCustom"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">
                    <FrameLayout
                        android:id="@+id/bgCustom"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_aspect_ratio_item">
                        <ImageView
                            android:id="@+id/icCustom"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_crop_24"
                            app:tint="@color/iconSecondary" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/txtCustom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/str_custom"
                        android:textColor="@color/toolTextInactive"
                        android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
</LinearLayout>