<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/str_fade_in"
        android:textColor="@color/textColor"
        android:fontFamily="sans-serif-medium"
        android:textSize="16sp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <com.google.android.material.slider.Slider
            android:id="@+id/fadeInSlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="0.0"
            android:valueTo="5.0"
            android:value="0.0"
            app:thumbColor="@color/colorPrimary"
            app:trackColorActive="@color/colorPrimary" />

        <TextView
            android:id="@+id/tvFadeInValue"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="@string/str_0_0s"
            android:textColor="@color/textColor"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/str_fade_out"
        android:textColor="@color/textColor"
        android:fontFamily="sans-serif-medium"
        android:textSize="16sp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <com.google.android.material.slider.Slider
            android:id="@+id/fadeOutSlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="0.0"
            android:valueTo="5.0"
            android:value="0.0"
            app:thumbColor="@color/colorPrimary"
            app:trackColorActive="@color/colorPrimary" />

        <TextView
            android:id="@+id/tvFadeOutValue"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="@string/str_0_0s"
            android:textColor="@color/textColor"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFadeDone"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:text="@string/done"
        android:textColor="@color/onPrimaryContainer"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="@color/primaryContainer"
        app:cornerRadius="24dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:elevation="0dp" />
</LinearLayout>
