<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surfaceContainerHigh"
    android:orientation="vertical"
    android:paddingBottom="48dp"
    android:paddingTop="12dp">

    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:alpha="0.4"
        android:background="@color/outlineVariant" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="24dp">

        <TextView
            android:id="@+id/tvTitleQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-medium"
            android:text="Export Settings"
            android:textColor="@color/textColor"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/btnCloseSheet"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close_24"
            app:tint="@color/activeTool" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <!-- High Quality Option -->
        <LinearLayout
            android:id="@+id/layoutQualityHigh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_aspect_ratio_item"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvQualityHighTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High Quality (1080p/Original)"
                    android:textColor="@color/textColor"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvQualityHighDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best visual quality, larger file size"
                    android:textColor="@color/iconSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivCheckHigh"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_24"
                app:tint="@color/colorPrimary"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Medium Quality Option -->
        <LinearLayout
            android:id="@+id/layoutQualityMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_aspect_ratio_item"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvQualityMediumTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medium Quality (Default)"
                    android:textColor="@color/textColor"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvQualityMediumDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Balanced quality and file size"
                    android:textColor="@color/iconSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivCheckMedium"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_24"
                app:tint="@color/colorPrimary"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Low Quality Option -->
        <LinearLayout
            android:id="@+id/layoutQualityLow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_aspect_ratio_item"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvQualityLowTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low Quality (Fastest)"
                    android:textColor="@color/textColor"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvQualityLowDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smallest file size, fastest export"
                    android:textColor="@color/iconSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivCheckLow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_24"
                app:tint="@color/colorPrimary"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
