<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_bottom_nav_floating"
        android:padding="24dp"
        android:elevation="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_voice_over"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/textColor"
                android:layout_centerVertical="true" />

            <ImageButton
                android:id="@+id/btnCloseVoiceOver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/iconSecondary"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_record_live_commentary_while_t"
            android:textColor="@color/textColor"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp">

                <View
                    android:id="@+id/ripple1"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_primary_container"
                    android:backgroundTint="#FF4081"
                    android:alpha="0" />

                <View
                    android:id="@+id/ripple2"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_primary_container"
                    android:backgroundTint="#FF4081"
                    android:alpha="0" />

                <ImageButton
                    android:id="@+id/btnToggleRecording"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mic_24"
                    android:background="@drawable/circle_primary_container"
                    app:tint="@android:color/white"
                    android:elevation="4dp"
                    android:padding="24dp"
                    android:scaleType="fitCenter"/>
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvRecordingStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_tap_to_start_recording"
            android:textColor="@color/textColor"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" />
            
    </LinearLayout>
</LinearLayout>
