<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chroma Key"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/textColor"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Key Color"
            android:textColor="@color/textColor"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/btnChromaEyedropper"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_color_picker_24"
            android:background="@drawable/tool_button_inactive"
            android:padding="8dp"
            app:tint="@color/textColor" />

        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/outline">
            <View
                android:id="@+id/chromaColorPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#00FF00" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <com.tharunbirla.librecuts.customviews.HSVColorPickerView
        android:id="@+id/hsvChromaColorPicker"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Intensity"
            android:textColor="@color/textColor"
            android:textSize="12sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/chromaIntensitySlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="0.01"
            android:valueTo="0.5"
            android:value="0.1"
            android:stepSize="0.01"
            app:thumbColor="@color/colorPrimary"
            app:trackColorActive="@color/colorPrimary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnChromaClear"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear"
            android:textColor="#F44336" />

        <Button
            android:id="@+id/btnChromaApply"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apply"
            android:textColor="@color/colorPrimary" />
    </LinearLayout>

</LinearLayout>
