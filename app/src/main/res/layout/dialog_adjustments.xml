<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_panel_background"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Title and Slider Label -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="@string/str_adjust"
            android:textColor="@color/textColor"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/adjustValueLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="@string/str_brightness_0"
            android:textColor="@color/colorPrimary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

    <!-- Slider for adjustments -->
    <com.google.android.material.slider.Slider
        android:id="@+id/adjustSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        android:valueFrom="-100.0"
        android:valueTo="100.0"
        android:value="0.0"
        app:thumbColor="@color/colorPrimary"
        app:trackColorActive="@color/colorPrimary"
        app:trackColorInactive="@color/toolTextInactive" />

    <!-- List of adjust options -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp">

        <LinearLayout
            android:id="@+id/adjustOptionsList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Action Buttons -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="12dp">

        <Button
            android:id="@+id/btnApplyToAll"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="@string/str_apply_to_all"
            android:textColor="@color/colorPrimary"
            app:strokeColor="@color/colorPrimary"
            app:strokeWidth="1.5dp"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/btnDone"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="@string/done"
            android:textColor="@color/colorOnPrimary"
            android:backgroundTint="@color/colorPrimary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

</LinearLayout>
