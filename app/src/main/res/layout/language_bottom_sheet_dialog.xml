<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surfaceContainerHigh"
    android:orientation="vertical"
    android:paddingBottom="48dp"
    android:paddingTop="12dp">

    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:alpha="0.4"
        android:background="@color/outlineVariant" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="24dp">

        <TextView
            android:id="@+id/tvTitleLanguage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-medium"
            android:text="@string/str_app_language"
            android:textColor="@color/textColor"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/btnCloseSheet"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close_24"
            app:tint="@color/activeTool" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <!-- System Default Option -->
        <LinearLayout
            android:id="@+id/layoutLangSystem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_aspect_ratio_item"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_system_default"
                android:textColor="@color/textColor"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/ivCheckLangSystem"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_24"
                app:tint="@color/colorPrimary"
                android:visibility="gone" />
        </LinearLayout>

        <!-- English Option -->
        <LinearLayout
            android:id="@+id/layoutLangEn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_aspect_ratio_item"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="English"
                android:textColor="@color/textColor"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/ivCheckLangEn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_24"
                app:tint="@color/colorPrimary"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Deutsch Option -->
        <LinearLayout
            android:id="@+id/layoutLangDe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_aspect_ratio_item"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Deutsch"
                android:textColor="@color/textColor"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/ivCheckLangDe"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_24"
                app:tint="@color/colorPrimary"
                android:visibility="gone" />
        </LinearLayout>
        
        <!-- Eesti Option -->
        <LinearLayout
            android:id="@+id/layoutLangEt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_aspect_ratio_item"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Eesti"
                android:textColor="@color/textColor"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/ivCheckLangEt"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_24"
                app:tint="@color/colorPrimary"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
