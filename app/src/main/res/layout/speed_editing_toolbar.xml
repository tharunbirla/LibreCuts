<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_bottom_nav_floating"
        android:paddingVertical="16dp"
        android:elevation="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/tvTitleSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_video_speed"
                android:textColor="@color/textColor"
                android:textSize="18sp" />

            <ImageButton
                android:id="@+id/btnCloseSpeedSheet"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/activeTool" />
        </RelativeLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layout_gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp">

                <!-- 0.5x -->
                <LinearLayout
                    android:id="@+id/speedBtn05"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <FrameLayout
                        android:id="@+id/bgSpeed05"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_aspect_ratio_item">
                        <TextView
                            android:id="@+id/txtSpeed05"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/str_0_5x"
                            android:textColor="@color/iconSecondary"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="16sp" />
                    </FrameLayout>
                </LinearLayout>

                <!-- 1.0x -->
                <LinearLayout
                    android:id="@+id/speedBtn10"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <FrameLayout
                        android:id="@+id/bgSpeed10"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_aspect_ratio_item">
                        <TextView
                            android:id="@+id/txtSpeed10"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/str_1x"
                            android:textColor="@color/iconSecondary"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="16sp" />
                    </FrameLayout>
                </LinearLayout>

                <!-- 1.5x -->
                <LinearLayout
                    android:id="@+id/speedBtn15"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <FrameLayout
                        android:id="@+id/bgSpeed15"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_aspect_ratio_item">
                        <TextView
                            android:id="@+id/txtSpeed15"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/str_1_5x"
                            android:textColor="@color/iconSecondary"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="16sp" />
                    </FrameLayout>
                </LinearLayout>

                <!-- 2.0x -->
                <LinearLayout
                    android:id="@+id/speedBtn20"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">
                    <FrameLayout
                        android:id="@+id/bgSpeed20"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_aspect_ratio_item">
                        <TextView
                            android:id="@+id/txtSpeed20"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/str_2x"
                            android:textColor="@color/iconSecondary"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="16sp" />
                    </FrameLayout>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Custom Speed Slider Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="24dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Custom Speed"
                    android:textColor="@color/textColor"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp" />
                    
                <TextView
                    android:id="@+id/tvCustomSpeedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="1.0x"
                    android:textColor="@color/colorPrimary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />
            </RelativeLayout>
            
            <com.google.android.material.slider.Slider
                android:id="@+id/sliderCustomSpeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.1"
                android:valueTo="10.0"
                android:value="1.0"
                android:stepSize="0.1"
                app:haloColor="#3300C3FF"
                app:thumbColor="@color/colorPrimary"
                app:trackColorActive="@color/colorPrimary"
                app:trackColorInactive="@color/surfaceVariant" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
