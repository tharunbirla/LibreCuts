<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_bottom_nav_docked"
        android:paddingVertical="16dp"
        android:paddingHorizontal="16dp"
        android:elevation="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:text="@string/str_subtitles"
                android:textColor="@color/textColor"
                android:textSize="18sp" />

            <ImageButton
                android:id="@+id/btnCloseSubtitlesSheet"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/activeTool" />
        </RelativeLayout>

        <!-- No subtitles state -->
        <LinearLayout
            android:id="@+id/layoutNoSubtitles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUploadSrt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_upload_subtitle_file"
                android:textAllCaps="false"
                android:textColor="@color/onPrimaryContainer"
                android:backgroundTint="@color/colorPrimary"
                app:cornerRadius="24dp"
                android:paddingHorizontal="24dp"
                android:paddingVertical="8dp"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/str_supports_standard_srt_formatte"
                android:textColor="@color/outline"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Subtitles active state -->
        <LinearLayout
            android:id="@+id/layoutHasSubtitles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_bottom_nav"
                android:padding="8dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_closed_caption_24"
                    app:tint="@color/colorPrimary" />

                <TextView
                    android:id="@+id/tvSubtitleFileName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/str_subtitles_srt"
                    android:textColor="@color/textColor"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium" />

                 <ImageButton
                    android:id="@+id/btnChangeSrt"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_swap_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/colorPrimary"
                    android:contentDescription="Change Subtitle File" />
            </LinearLayout>

            <!-- Font Size Slider Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_text_24"
                    app:tint="@color/iconSecondary" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/subtitleFontSizeSlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="10.0"
                    android:valueTo="80.0"
                    android:value="22.0"
                    android:stepSize="1.0"
                    app:thumbColor="@color/colorPrimary"
                    app:trackColorActive="@color/colorPrimary" />

                <TextView
                    android:id="@+id/tvSubtitleFontSizeValue"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="@string/str_22"
                    android:textColor="@color/textColor"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteSrt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/str_remove"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textAllCaps="false"
                    android:textColor="#F44336"
                    app:strokeColor="#F44336"
                    app:cornerRadius="24dp"
                    android:layout_marginEnd="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveSubtitles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/str_save"
                    android:backgroundTint="@color/colorPrimary"
                    android:textColor="@android:color/white"
                    app:cornerRadius="24dp"
                    android:textAllCaps="false"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
