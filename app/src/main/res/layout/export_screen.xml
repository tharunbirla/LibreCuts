<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/exportScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:visibility="gone">

    <!-- Semi-transparent overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <!-- Center content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Lottie Animation -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieExportAnimation"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:lottie_rawRes="@raw/process"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"/>

        <!-- Title Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Exporting Video"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="24sp" />

        <!-- Subtitle Text -->
        <TextView
            android:id="@+id/tvExportMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Processing your edits...\nThis may take a moment"
            android:textAlignment="center"
            android:textColor="#CCCCCC"
            android:textSize="14sp" />

        <!-- Progress indicator -->
        <ProgressBar
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="24dp"
            android:indeterminate="true"
            android:indeterminateTint="@android:color/white" />

    </LinearLayout>

</FrameLayout>
