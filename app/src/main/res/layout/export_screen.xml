<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/exportScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000"
    android:visibility="gone"
    android:clickable="true"
    android:focusable="true">

    <!-- Center Bento Modal Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="@color/surfaceContainerHigh"
        app:strokeColor="@color/outlineVariant"
        app:strokeWidth="1dp"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Title Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_saving_video"
                android:textColor="@color/textColor"
                android:fontFamily="sans-serif-medium"
                android:textSize="20sp" />

            <!-- Subtitle Text -->
            <TextView
                android:id="@+id/tvExportMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/str_please_don_t_close_the_app"
                android:textAlignment="center"
                android:textColor="@color/outline"
                android:fontFamily="sans-serif"
                android:textSize="14sp" />

            <!-- Progress Indicator with Percentage -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="24dp">
                
                <ProgressBar
                    android:id="@+id/exportProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:progressDrawable="@drawable/circular_progress_bar"
                    android:max="100"
                    android:progress="0" />
                
                <TextView
                    android:id="@+id/tvExportPercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/str_0"
                    android:textColor="@color/colorPrimary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="18sp" />
            </FrameLayout>

            <!-- Cancel Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelExport"
                android:layout_width="160dp"
                android:layout_height="44dp"
                android:layout_marginTop="28dp"
                android:text="@string/cancel"
                android:textColor="@color/textColor"
                android:backgroundTint="@color/surfaceVariant"
                app:strokeWidth="0dp"
                app:cornerRadius="22dp"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
