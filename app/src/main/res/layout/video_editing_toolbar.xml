<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="16dp"
    android:layout_marginBottom="24dp"
    android:scrollbars="none"
    android:background="@drawable/bg_bottom_nav_floating"
    android:elevation="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:paddingHorizontal="8dp">

        <!-- Cancel -->
        <LinearLayout
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoCancel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_close_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cancel"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Trim -->
        <LinearLayout
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoTrim"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_trim_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Trim"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Split -->
        <LinearLayout
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoSplit"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_cut_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Split"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Mute Clip -->
        <LinearLayout
            android:id="@+id/btnVideoMuteContainer"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoMute"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_volume_up_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:id="@+id/tvVideoMuteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Mute"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Color Filters / LUTs -->
        <LinearLayout
            android:id="@+id/btnVideoFilterContainer"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoFilter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_palette_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Filters"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Adjust -->
        <LinearLayout
            android:id="@+id/btnVideoAdjustContainer"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoAdjust"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_tune_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Adjust"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Speed -->
        <LinearLayout
            android:id="@+id/btnVideoSpeedContainer"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoSpeed"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_speed_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Speed"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Extract Audio -->
        <LinearLayout
            android:id="@+id/btnVideoExtractAudioContainer"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoExtractAudio"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_audio_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Extract"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Freeze Frame -->
        <LinearLayout
            android:id="@+id/btnVideoFreezeFrameContainer"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoFreezeFrame"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_freeze_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Freeze"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Reverse -->
        <LinearLayout
            android:id="@+id/btnVideoReverseContainer"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoReverse"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_fast_rewind_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Reverse"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <!-- Delete -->
        <LinearLayout
            android:id="@+id/btnVideoDeleteContainer"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoDelete"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_delete_24"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/colorPrimary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Delete"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/colorPrimary"/>
        </LinearLayout>

    </LinearLayout>
</HorizontalScrollView>
