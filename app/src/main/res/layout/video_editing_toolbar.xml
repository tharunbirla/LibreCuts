<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="16dp"
    android:layout_marginBottom="24dp"
    android:orientation="horizontal"
    android:gravity="center"
    android:background="@drawable/bg_bottom_nav_floating"
    android:paddingVertical="12dp"
    android:paddingHorizontal="8dp"
    android:elevation="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">
        <ImageButton
            android:id="@+id/btnVideoCancel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/tool_button_inactive"
            android:src="@drawable/ic_close_24"
            app:tint="@color/toolTextInactive" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Cancel"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/toolTextInactive"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">
        <ImageButton
            android:id="@+id/btnVideoTrim"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/tool_button_inactive"
            android:src="@drawable/ic_trim_24"
            app:tint="@color/toolTextInactive" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Trim"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/toolTextInactive"/>
    </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnVideoSplit"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_cut_24"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Split"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:id="@+id/btnVideoSpeedContainer">
            <ImageButton
                android:id="@+id/btnVideoSpeed"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_speed_24"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Speed"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:id="@+id/btnVideoExtractAudioContainer">
            <ImageButton
                android:id="@+id/btnVideoExtractAudio"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_audio_24"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Extract"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:id="@+id/btnVideoFreezeFrameContainer">
            <ImageButton
                android:id="@+id/btnVideoFreezeFrame"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_freeze_24"
                app:tint="@color/toolTextInactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Freeze"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/toolTextInactive"/>
        </LinearLayout>


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:id="@+id/btnVideoDeleteContainer">
            <ImageButton
                android:id="@+id/btnVideoDelete"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/tool_button_inactive"
                android:src="@drawable/ic_delete_24"
                app:tint="@color/colorPrimary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Delete"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/colorPrimary"/>
        </LinearLayout>

</LinearLayout>
